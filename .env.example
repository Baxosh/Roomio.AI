# ==========================================
# Vanna AI Application Configuration
# ==========================================

# DeepSeek / LLM Configuration
DEEPSEEK_API_KEY=your-deepseek-api-key-here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=  # Optional, leave empty for unlimited

# ==========================================
# EXISTING Database Configuration
# ==========================================
# NOTE: This application connects to your EXISTING PostgreSQL database.
# It does NOT create or manage the database itself.
#
# For Docker deployment connecting to localhost database:
#   Use: POSTGRES_HOST=host.docker.internal
#   And uncomment extra_hosts in docker-compose.yml
#
# For remote database:
#   Use: POSTGRES_HOST=your-db-server.com (or IP address)
# ==========================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=grms
POSTGRES_USER=your-db-user
POSTGRES_PASSWORD=your-db-password

# Agent Configuration
AGENT_MAX_ITERATIONS=50
AGENT_STREAM_RESPONSES=true
AGENT_AUTO_SAVE_CONVERSATIONS=true
AGENT_THINKING_INDICATORS=true

# Application Configuration
APP_PORT=8000
SCHEMA_FILE=structure.txt
CHROMA_DB_PATH=./chroma_db

# FastAPI Configuration
FASTAPI_TITLE=Vanna AI - SQL Query Assistant
FASTAPI_VERSION=0.1.0
FASTAPI_DESCRIPTION=Multi-tenant SQL query assistant powered by Vanna AI and DeepSeek
FASTAPI_DEV_MODE=false
# FASTAPI_STATIC_FOLDER=  # Optional path to static files

# CORS Configuration
CORS_ENABLED=true
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=*

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/vanna_app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# HuggingFace Tokenizers Configuration
# Prevents fork warnings when using tokenizers library
TOKENIZERS_PARALLELISM=false
